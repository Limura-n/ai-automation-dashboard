#############################################################################
# Adobe Stock Mission Control — Environment Configuration
# Copy this to .env and fill in your values
#############################################################################

# --- Database ---
# SQLite (default — works out of the box, no setup needed)
DATABASE_URL="file:./prisma/db/custom.db"
# For Postgres (optional): DATABASE_URL="postgresql://user:password@localhost:5432/mission_control"

# --- AI Backend: Hermes Gateway ---
# This is the HTTP bridge that powers the Terminal Chat and Super Agent.
# Run your own Hermes instance or point to a running gateway.
HERMES_BASE_URL="http://localhost:8000"

# --- API Keys ---
# OpenCode API Key — required for the Super Agent worker (get from https://opencode.ai/auth)
OPENCODE_GO_API_KEY="oc_..."
# OpenRouter API Key — optional, for additional model routing (get from https://openrouter.ai)
OPENROUTER_API_KEY="sk-or-..."

# --- Telegram Bot (optional) ---
# Create a bot via @BotFather on Telegram, then paste the token here.
# TELEGRAM_BOT_TOKEN="123456:ABC-DEF1234ghIkl-zyx57W2v1u123ew11"

# --- Session Secret (for next-auth) ---
# Generate with: openssl rand -hex 32
# NEXTAUTH_SECRET="..."
# NEXTAUTH_URL="http://localhost:3000"
