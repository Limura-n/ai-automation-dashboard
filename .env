DATABASE_URL=file:./prisma/db/custom.db
HERMES_BASE_URL=http://localhost:8000

# OpenCode API Keys (get from https://opencode.ai/auth)
OPENCODE_GO_API_KEY=
OPENCODE_ZEN_API_KEY=

